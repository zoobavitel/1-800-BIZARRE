# Copy to /opt/bizarre/backend/src/.env and adjust. Never commit .env.

SECRET_KEY=
# Comma-separated hosts (LAN + public API hostname + Tailscale name if used)
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.204,bizarre-api
# Comma-separated origins — must include GitHub Pages SPA origin
CORS_ALLOWED_ORIGINS=https://zoobavitel.github.io
# Same-origin list for CSRF (browser forms / session login from those origins). Mirror
# CORS when using session auth from GitHub Pages or a LAN dev server.
CSRF_TRUSTED_ORIGINS=https://zoobavitel.github.io,http://192.168.1.204,http://bizarre-api
# Set false when testing HTTP-only on LAN before TLS
DJANGO_SECURE_SSL_REDIRECT=true
# Set false with HTTP-only LAN so browsers accept session/CSRF cookies (Secure cookies do not work on http://)
DJANGO_SECURE_COOKIES=true

DB_NAME=bizarre_db
DB_USER=bizarre
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0

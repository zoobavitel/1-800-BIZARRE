# Copy to /opt/bizarre/backend/src/.env and adjust. Never commit .env.

SECRET_KEY=
# Comma-separated hosts (LAN + public API hostname + Tailscale name if used)
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.204,bizarre-api
# Comma-separated origins — must include GitHub Pages SPA origin
CORS_ALLOWED_ORIGINS=https://zoobavitel.github.io
# Set false when testing HTTP-only on LAN before TLS
DJANGO_SECURE_SSL_REDIRECT=true

DB_NAME=bizarre_db
DB_USER=bizarre
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

REDIS_URL=redis://127.0.0.1:6379/0
